# Copy this to .env and fill in real values before running: docker compose up -d
# Never commit .env to version control.

# PostgreSQL password — shared between the DB service and the app's DATABASE_URL.
# Use a strong random value: openssl rand -hex 16
POSTGRES_PASSWORD=change_me_to_a_strong_random_password

# Better Auth secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change_me_to_a_64_char_random_secret

# Public URL the app is reachable at (used by Better Auth for redirects and CSRF checks).
# Local network, direct port:     http://192.168.1.x:3000
# Behind Caddy with DuckDNS:      https://yourname.duckdns.org
BETTER_AUTH_URL=http://localhost:3000

# Host port to expose the app on (default: 3000). Uncomment to change.
# APP_PORT=3000
